rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isEmailVerified() && request.auth.token.email == 'nomair836@gmail.com'; }

    function isValidProject(data) {
      return data.keys().hasAll(['clientEmail', 'title', 'status', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 6 &&
             data.clientEmail is string && data.clientEmail.size() <= 200 &&
             data.title is string && data.title.size() <= 200 &&
             data.status is string && data.status.size() <= 100 &&
             (!('telegramLink' in data) || (data.telegramLink is string && data.telegramLink.size() <= 500));
    }

    match /projects/{projectId} {
      allow get: if isEmailVerified() && isValidId(projectId) && (isAdmin() || existing().clientEmail == request.auth.token.email);
      allow list: if isEmailVerified() && (isAdmin() || resource.data.clientEmail == request.auth.token.email);
      allow create: if isAdmin() &&
                    isValidProject(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isAdmin() &&
                    isValidProject(incoming()) &&
                    isValidId(projectId) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
      allow delete: if isAdmin() && isValidId(projectId);
    }
  }
}
